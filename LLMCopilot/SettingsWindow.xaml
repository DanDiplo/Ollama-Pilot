<Window x:Class="OllamaPilot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ollama Pilot Settings"
        Width="760"
        Height="680"
        MinWidth="720"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="20,20,20,12"
                Padding="20"
                CornerRadius="18"
                Background="#0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
        <TextBlock Text="Ollama Pilot Settings"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="Tune Ollama chat, completion, and fill-in-the-middle settings from one place."
                               Margin="0,8,0,0"
                               Foreground="#CBD5E1"
                               TextWrapping="Wrap" />
                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Fast Preset"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Click="FastPreset_Click" />
                        <Button Content="Balanced Preset"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Click="BalancedPreset_Click" />
                        <Button Content="Quality Preset"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Click="QualityPreset_Click" />
                        <Button Content="Recommended Models"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Click="RecommendedModels_Click" />
                        <Button Content="Recommended Contexts"
                                Padding="12,6"
                                Click="RecommendedContexts_Click" />
                    </WrapPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Test Connection"
                        Padding="14,8"
                        Margin="20,0,0,0"
                        VerticalAlignment="Top"
                        Click="TestConnection_Click" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,12"
                        Padding="18"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Connection"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827" />
                            <TextBlock Text="Point the extension at your local or proxied Ollama endpoint."
                                       Margin="0,4,0,12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Base URL"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="BaseUrlTextBox"
                                     Margin="0,6,0,12"
                                     MinWidth="280" />
                            <TextBlock Text="Reverse Proxy Access Token"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="AccessTokenTextBox"
                                     Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock Text="Response Language"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="LanguageComboBox"
                                      Margin="0,6,0,12" />
                            <TextBlock Text="Available Models"
                                       FontWeight="SemiBold" />
                            <DockPanel Margin="0,6,0,8">
                                <Button Content="Refresh"
                                        Width="88"
                                        Click="RefreshModels_Click"
                                        DockPanel.Dock="Right" />
                                <TextBlock Text="Load local Ollama model names into the selectors below."
                                           Margin="0,4,10,0"
                                           Foreground="#6B7280"
                                           TextWrapping="Wrap" />
                            </DockPanel>
                            <ListBox x:Name="ModelsListBox"
                                     Height="160"
                                     BorderBrush="#D1D5DB" />
                            <TextBlock x:Name="RecommendationTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="#4B5563"
                                       TextWrapping="Wrap"
                                       Text="Tip: use a larger reasoning model for chat and a smaller coder model for completion." />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,12"
                        Padding="18"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Chat"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827" />
                            <TextBlock Text="Use a larger reasoning model here for explanations and edits."
                                       Margin="0,4,0,12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Chat Model"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="ChatModelComboBox"
                                      Margin="0,6,0,12"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False" />
                            <TextBlock Text="Chat Context Length"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="ChatCtxTextBox"
                                     Margin="0,6,0,12" />
                            <TextBlock Text="Thinking Depth"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="ThinkingDepthComboBox"
                                      Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock Text="Completion"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827" />
                            <TextBlock Text="Use a faster coder model here for inline suggestions."
                                       Margin="0,4,0,12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Code Complete Model"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="CompleteModelComboBox"
                                      Margin="0,6,0,12"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False" />
                            <TextBlock Text="Complete Context Length"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="CompleteCtxTextBox"
                                     Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Autocomplete"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827" />
                            <TextBlock Text="Control when inline completions fire and how much text they need before asking Ollama."
                                       Margin="0,4,0,12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap" />
                            <CheckBox x:Name="EnableAutoCompleteCheckBox"
                                      Content="Enable Auto Complete"
                                      Margin="0,0,0,12" />
                            <TextBlock Text="Trigger Mode"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="TriggerModeComboBox"
                                      Margin="0,6,0,12" />
                            <TextBlock Text="Delay (ms)"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="AutoCompleteDelayTextBox"
                                     Margin="0,6,0,12" />
                            <TextBlock Text="Minimum Prefix Length"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="AutoCompleteMinPrefixTextBox"
                                     Margin="0,6,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0">
                            <TextBlock Text="FIM Tokens"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827" />
                            <TextBlock Text="Match these to the selected completion model template."
                                       Margin="0,4,0,12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="FIM Begin"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="FimBeginTextBox"
                                     Margin="0,6,0,12" />
                            <TextBlock Text="FIM Hole"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="FimHoleTextBox"
                                     Margin="0,6,0,12" />
                            <TextBlock Text="FIM End"
                                       FontWeight="SemiBold" />
                            <TextBox x:Name="FimEndTextBox"
                                     Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1,1,1,0">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#6B7280"
                           Text="Ready." />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="Cancel"
                            Width="96"
                            Margin="0,0,8,0"
                            Click="Cancel_Click" />
                    <Button Content="Save Settings"
                            Width="120"
                            Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
