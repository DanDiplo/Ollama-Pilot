<UserControl x:Class="OllamaPilot.LLMChatWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:local="clr-namespace:OllamaPilot"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Name="MyToolWindow">
    <UserControl.Resources>
        <local:CapitalizeFirstLetterConverter x:Key="CapitalizeFirstLetterConverter" />
        <local:AssistantMessageVisibilityConverter x:Key="AssistantMessageVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:MessageSegmentTemplateSelector x:Key="MessageSegmentTemplateSelector" />
        <DataTemplate x:Key="MarkdownSegmentTemplate">
            <md:MarkdownScrollViewer MarkdownStyleName="Sasabune"
                                     Markdown="{Binding Content}"
                                     Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"
                                     VerticalAlignment="Stretch"
                                     HorizontalAlignment="Stretch" />
        </DataTemplate>
        <DataTemplate x:Key="CodeSegmentTemplate">
            <Border Margin="0,4,0,4"
                    Padding="1"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}">
                <Grid>
                    <TextBlock Text="{Binding LanguageLabel}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Margin="0,6,10,0"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextInactiveKey}}" />
                    <local:CodeBlockViewer Code="{Binding Content}"
                                           Language="{Binding Language}"
                                           Margin="0,18,0,0"
                                           MinHeight="40" />
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="MessageTemplate">
            <Border Padding="12"
                    Margin="6"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientBeginKey}}">
                <StackPanel>
                    <Border Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}"
                            CornerRadius="999"
                            HorizontalAlignment="Left"
                            Padding="8,3"
                            Margin="0,0,0,8">
                        <TextBlock Text="{Binding Role, Converter={StaticResource CapitalizeFirstLetterConverter}}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding Segments}"
                                  ItemTemplateSelector="{StaticResource MessageSegmentTemplateSelector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,8,0,0"
                                Visibility="{Binding Role, Converter={StaticResource AssistantMessageVisibilityConverter}}">
                        <Button Content="Preview Diff"
                                Click="PreviewDiff_Click"
                                Tag="{Binding}"
                                Margin="0,0,8,0" />
                        <Button Content="Copy Code"
                                Click="CopyCode_Click"
                                Tag="{Binding}"
                                Margin="0,0,8,0" />
                        <Button Content="Use As Draft"
                                Click="UseAsDraft_Click"
                                Tag="{Binding}"
                                Margin="0,0,8,0" />
                        <Button Content="Create Sibling File"
                                Click="CreateSiblingFile_Click"
                                Tag="{Binding}"
                                Margin="0,0,8,0" />
                        <Button Content="Insert Into Editor"
                                Click="InsertIntoEditor_Click"
                                Tag="{Binding}"
                                Margin="0,0,8,0" />
                        <Button Content="Replace Selection"
                                Click="ReplaceSelection_Click"
                                Tag="{Binding}"
                                Margin="0,0,8,0" />
                        <Button Content="Replace File"
                                Click="ReplaceFile_Click"
                                Tag="{Binding}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <Style x:Key="MenuItemStyle"
               TargetType="MenuItem">
            <Setter Property="Background"
                    Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientBeginKey}}" />
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static vsshell:VsBrushes.MenuTextKey}}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="1">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  Margin="6,3,6,3"
                                                  RecognizesAccessKey="True" />
                                <Popup x:Name="Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border x:Name="SubmenuBorder"
                                            Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientBeginKey}}"
                                            BorderThickness="0">
                                        <ScrollViewer CanContentScroll="True"
                                                      Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Menu Grid.Row="0"
              Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientBeginKey}}"
              Foreground="{DynamicResource {x:Static vsshell:VsBrushes.MenuTextKey}}">
            <MenuItem Header="_Menu"
                      Style="{StaticResource MenuItemStyle}">
                <MenuItem Header="_List models"
                          Click="ListModels_Click"
                          Style="{StaticResource MenuItemStyle}" />
                <Separator Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientBeginKey}}"
                           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.MenuTextKey}}" />
                <MenuItem Header="_Clear chat history"
                          Click="ClearChatHistory_Click"
                          Style="{StaticResource MenuItemStyle}" />
            </MenuItem>
            <MenuItem Header="_Options"
                      Style="{StaticResource MenuItemStyle}">
                <MenuItem Header="_Settings"
                          Click="SettingsMenuItem_Click"
                          Style="{StaticResource MenuItemStyle}" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1"
                Margin="8,8,8,4"
                Padding="14"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandShelfHighlightGradientBeginKey}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0">
                    <TextBlock Text="Local Ollama Workspace"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" />
                    <TextBlock Text="{Binding StatusText}"
                               Margin="0,4,0,0"
                               Foreground="{Binding StatusBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="Test Connection"
                            Click="TestConnection_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Regenerate Last"
                            Click="RegenerateLast_Click"
                            Margin="0,0,8,0"
                            IsEnabled="{Binding CanRegenerateLast}" />
                    <Button Content="Cancel Response"
                            Click="CancelResponse_Click"
                            IsEnabled="{Binding CanCancelResponse}" />
                </StackPanel>

                <WrapPanel Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,12,0,0">
                    <Border Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}"
                            CornerRadius="999"
                            Padding="10,5"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding ChatModelBadge}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}"
                            CornerRadius="999"
                            Padding="10,5"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding CompletionModelBadge}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}"
                            CornerRadius="999"
                            Padding="10,5">
                        <TextBlock Text="{Binding AutoCompleteBadge}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="MessagesScrollViewer"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MessageItemsControl"
                          Background="Transparent"
                          ItemsSource="{Binding Messages}"
                          ItemTemplate="{StaticResource MessageTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
        <Border Grid.Row="3"
                Margin="8,4,8,8"
                Padding="10"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"
                Background="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarGradientBeginKey}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <WrapPanel Grid.Row="0"
                           Margin="0,0,0,8">
                    <Button Content="Review File"
                            Click="ReviewFile_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Test File"
                            Click="GenerateTestsForFile_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Summarize Changes"
                            Click="SummarizeChanges_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Explain Error"
                            Click="ExplainError_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Edit Selection"
                            Click="EditSelection_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Insert Selection"
                            Click="InsertSelectionIntoPrompt_Click"
                            Margin="0,0,8,0" />
                    <Button Content="Clear Draft"
                            Click="ClearDraft_Click"
                            Margin="0,0,8,0" />
                    <TextBlock Text="Ctrl+Enter sends"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextInactiveKey}}" />
                </WrapPanel>

                <TextBox x:Name="MessageTextBox"
                         Grid.Row="1"
                         MinWidth="200"
                         MinHeight="82"
                         VerticalContentAlignment="Top"
                         KeyDown="MessageTextBox_KeyDown"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         GotFocus="MessageTextBox_GotFocus"
                         LostFocus="MessageTextBox_LostFocus"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="Gray"
                         Text="Ask Ollama for an explanation, refactor, test, or paste selected code into the prompt." />

                <DockPanel Grid.Row="2"
                           Margin="0,8,0,0">
                    <TextBlock Text="{Binding DraftHintText}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarTextInactiveKey}}" />
                    <Button x:Name="SendButton"
                            Content="Send"
                            Click="SendButton_Click"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            MinWidth="88" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
