<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0">
    <Grid Margin="12">
        <Grid.Resources>
            <Style TargetType="Label" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.ThemedDialogLabelStyleKey}}" />
            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.ThemedDialogTextBoxStyleKey}}" />
            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.ThemedDialogCheckBoxStyleKey}}" />
            <Style TargetType="Button" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.ThemedDialogButtonStyleKey}}" />
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Ollama Chat" FontWeight="Bold" Margin="0,0,0,10" />
        <Label Grid.Row="1" Content="Prompt" Margin="0,0,0,4" />

        <Border Grid.Row="2" BorderBrush="#666" BorderThickness="1" Padding="6" Margin="0,0,0,10">
            <TextBox Text="{Binding UserPrompt}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="72" MaxHeight="130" BorderThickness="0" Background="Transparent" />
        </Border>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Label Content="{Binding ActionName}" DockPanel.Dock="Left" />
                <Label Content="{Binding Status}" DockPanel.Dock="Right" />
            </DockPanel>

            <Border Grid.Row="1" BorderBrush="#666" BorderThickness="1" Padding="6">
                <TextBox Text="{Binding StreamingText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" />
            </Border>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <CheckBox Content="Include current selection" IsChecked="{Binding IncludeSelection}" Margin="0,0,0,6" />
            <WrapPanel Orientation="Horizontal">
                <Button Content="Apply Code" Command="{Binding ApplyCodeCommand}" Margin="0,0,8,8" MinWidth="95" />
                <Button Content="Copy Code" Command="{Binding CopyCodeCommand}" Margin="0,0,8,8" MinWidth="95" />
                <Button Content="Send" Command="{Binding SendCommand}" Margin="0,0,8,8" MinWidth="80" />
                <Button Content="Stop" Command="{Binding StopCommand}" Margin="0,0,8,8" MinWidth="80" />
                <Button Content="Copy Response" Command="{Binding CopyResponseCommand}" Margin="0,0,8,8" MinWidth="115" />
                <Button Content="Clear" Command="{Binding ClearCommand}" Margin="0,0,8,8" MinWidth="80" />
            </WrapPanel>
        </StackPanel>

        <Border Grid.Row="5" BorderBrush="#666" BorderThickness="1" Padding="6" Margin="0,0,0,10">
            <TextBox Text="{Binding CodeBlock}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" BorderThickness="0" Background="Transparent" />
        </Border>

        <Label Grid.Row="6" Content="Conversation" Margin="0,0,0,4" />
        <Border Grid.Row="7" BorderBrush="#444" BorderThickness="1" Padding="6">
            <TextBox Text="{Binding ConversationText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" />
        </Border>
    </Grid>
</DataTemplate>
